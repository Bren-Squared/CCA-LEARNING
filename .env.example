# CCA Foundations Learning App — local environment
#
# NOTE: ANTHROPIC_API_KEY is NOT set here. The first-run Settings wizard
# (FR5.1) collects it from the user and persists it encrypted in the SQLite
# `settings` table. The backend reads it from there. Never put the API key in
# this file; never commit it. The frontend never sees it (FR5.3 / AT10).

# SQLite database file path, relative to repo root. Gitignored.
DATABASE_URL=./data/app.sqlite

# Default Claude model used for generation, grading, and tutoring.
# Overridable in-app under Settings.
DEFAULT_MODEL=claude-sonnet-4-6

# Cheap model used for the independent reviewer pass (D4.6) and bulk
# question generation via the Message Batches API (D4.5).
CHEAP_MODEL=claude-haiku-4-5-20251001
